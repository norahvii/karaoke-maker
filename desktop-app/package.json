{
  "name": "karaoke-maker",
  "version": "1.0.0",
  "description": "AI-powered karaoke creation tool with mobile control",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"electron .\"",
    "dev:renderer": "vite --port 3001",
    "build": "npm run build:renderer && electron-builder",
    "build:renderer": "vite build",
    "postinstall": "electron-builder install-app-deps",
    "python:setup": "pip install -r python-pipeline/requirements.txt"
  },
  "build": {
    "appId": "com.karaokemaker.app",
    "productName": "Karaoke Maker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "python-pipeline/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "python-pipeline",
        "to": "python-pipeline"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "electron-store": "^8.1.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^8.0.0"
  }
}
